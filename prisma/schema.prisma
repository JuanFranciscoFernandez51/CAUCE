generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ════════════════════════════════════════════════
// USUARIOS Y AUTH
// ════════════════════════════════════════════════

enum Role {
  ADMIN
  CLIENT
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  email        String?  @unique
  passwordHash String
  name         String
  role         Role     @default(CLIENT)
  osRole       String   @default("dueno") // dueno | equipo — rol DENTRO del software del tenant
  clientId     String? // tenant al que pertenece (si role=CLIENT)
  client       Client?  @relation(fields: [clientId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ════════════════════════════════════════════════
// CLIENTE = TENANT DE CAUCE OS
// ════════════════════════════════════════════════

enum Pack {
  NONE
  STARTER
  PRO
  SCALE
  CUSTOM
}

enum ClientStatus {
  PROSPECT
  ONBOARDING
  ACTIVE
  PAUSED
  CHURNED
}

model Client {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique // subdominio: slug.cauce.app
  rubro       String? // libre: "taller de motos", "consultorio", etc.
  pack        Pack         @default(NONE)
  status      ClientStatus @default(PROSPECT)
  mrr         Float        @default(0) // USD mensual
  setupPaid   Float        @default(0) // USD setup cobrado
  costEstUsd  Float        @default(0) // costo variable estimado/mes
  health      Int          @default(100) // 0-100 salud de la cuenta
  // Cauce OS — personalización por configuración, JAMÁS fork
  branding    Json? // { logo, colors:{primary,...}, font }
  modules     String[]     @default([]) // ["crm","turnos","catalogo","rrhh","caja"]
  customFields Json? // { contact:[{key,label,type}], appointment:[...], product:[...] }
  domain      String? // dominio propio opcional
  settings    Json? // horarios, datos del negocio, FAQs del bot, etc.
  contactName String?
  email       String?
  phone       String?
  whatsapp    String?
  notes       String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  users        User[]
  leads        Lead[]
  projects     Project[]
  procesos     Proceso[]
  pantallas         Pantalla[]
  pantallaContratos PantallaContrato[]
  usages       Usage[]
  subscriptions Subscription[]
  invoices     Invoice[]
  reports      Report[]
  credentials  Credential[]
  contacts     Contact[]
  appointments Appointment[]
  availability Availability[]
  tasks        CrmTask[]
  products     Product[]
  employees    Employee[]
  timeEntries  TimeEntry[]
  cashMovements CashMovement[]
  cajaDias     CajaDia[]
  outreach     OutreachTarea[]
  listaEspera  ListaEspera[]
  costosFijos  CostoFijo[]
  ordenesTrabajo OrdenTrabajo[]
  ventas       Venta[]
  eventos      Evento[]
  actividad    Actividad[]
  presupuestosTaller PresupuestoTaller[]
  accounts     Account[]
  records      ContactRecord[]
  attachments  Attachment[]
  listings     Listing[]
  proyectos    Proyecto[]
  proyectoTareas ProyectoTarea[]
}

// Credenciales de canales del cliente — SIEMPRE cifradas AES-256-GCM
model Credential {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  kind      String // "whatsapp" | "instagram" | "sheets" | "other"
  label     String
  dataEnc   String // payload JSON cifrado AES-256-GCM (iv:tag:cipher base64)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ════════════════════════════════════════════════
// ENTRADA: LEADS, INTAKE, CONSULTORÍA
// ════════════════════════════════════════════════

enum LeadSource {
  INTAKE
  CONSULTORIA
  MANUAL
  BOT
}

enum LeadStatus {
  NEW
  QUALIFIED
  CONVERTED
  LOST
}

model Lead {
  id        String     @id @default(cuid())
  source    LeadSource
  status    LeadStatus @default(NEW)
  name      String
  business  String?
  rubro     String?
  email     String?
  phone     String?
  whatsapp  String?
  score     Int        @default(0) // 0-100
  intake    Json? // respuestas del scorecard: dolor, frecuencia, apps, urgencia, presupuesto
  clientId  String? // si se convirtió
  client    Client?    @relation(fields: [clientId], references: [id])
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  projects     Project[]
  blueprints   Blueprint[]
  consultNotes ConsultNote[]
}

enum ConsultStatus {
  SCHEDULED
  DONE
  ROADMAP_SENT
  CANCELLED
}

model ConsultNote {
  id          String        @id @default(cuid())
  leadId      String
  lead        Lead          @relation(fields: [leadId], references: [id], onDelete: Cascade)
  scheduledAt DateTime?
  status      ConsultStatus @default(SCHEDULED)
  callNotes   String? // notas de la llamada
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  roadmap     Roadmap?
}

model Roadmap {
  id            String      @id @default(cuid())
  consultNoteId String      @unique
  consultNote   ConsultNote @relation(fields: [consultNoteId], references: [id], onDelete: Cascade)
  content       Json // { fases:[{titulo, items:[{receta, area, nivel, impacto}], precioEstimado}] }
  priceUsd      Float? // precio del roadmap si es pago
  status        String      @default("draft") // draft | sent | accepted
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

// ════════════════════════════════════════════════
// DELIVERY: PROYECTOS, BLUEPRINTS, RECETAS, AUTOMATIZACIONES
// ════════════════════════════════════════════════

enum Stage {
  LEAD
  DIAGNOSTICO
  APROBACION
  BUILD
  QA
  ONBOARDING
  ACTIVO
}

enum Level {
  N1
  N2
  N3
  N4
}

model Project {
  id        String   @id @default(cuid())
  title     String
  stage     Stage    @default(LEAD)
  level     Level    @default(N1)
  setupFee  Float    @default(0)
  order     Int      @default(0) // posición en la columna del kanban
  notes     String?
  leadId    String?
  lead      Lead?    @relation(fields: [leadId], references: [id])
  clientId  String?
  client    Client?  @relation(fields: [clientId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  blueprints Blueprint[]
}

enum BlueprintStatus {
  DRAFT
  APPROVED
  REJECTED
}

model Blueprint {
  id               String          @id @default(cuid())
  leadId           String?
  lead             Lead?           @relation(fields: [leadId], references: [id])
  projectId        String?
  project          Project?        @relation(fields: [projectId], references: [id])
  status           BlueprintStatus @default(DRAFT)
  level            Level
  summary          String // diagnóstico en lenguaje claro
  flow             Json // flujo propuesto paso a paso
  recipeIds        String[]        @default([])
  suggestedPack    Pack
  suggestedSetup   Float
  suggestedMonthly Float
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

enum BizArea {
  ATENCION
  VENTAS_CRM
  MARKETING
  OPERACIONES
  TURNOS
  RRHH
  FINANZAS
}

// ════════════════════════════════════════════════
// PROCESOS — cómo está armado el negocio del cliente.
// Lista simple y en criollo: qué corre, cuándo y qué resuelve.
// La lógica vive en el código (crons, emails, wa.me), no en herramientas externas.
// ════════════════════════════════════════════════

enum ProcesoEstado {
  ACTIVO
  PAUSADO
}

model Proceso {
  id          String        @id @default(cuid())
  clientId    String
  client      Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  nombre      String // "Recordatorio de service"
  queHace     String // "Le avisa al cliente por WhatsApp que le toca el service"
  cuando      String // "Todos los días a las 9:00" | "Cuando entra una consulta"
  estado      ProcesoEstado @default(ACTIVO)
  orden       Int           @default(0)
  ultimaCorrida DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([clientId, orden])
}

// ════════════════════════════════════════════════
// USO, BILLING, REPORTES
// ════════════════════════════════════════════════

model Usage {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  period    String // "2026-06"
  messages  Int      @default(0)
  tokensIn  Int      @default(0)
  tokensOut Int      @default(0)
  costUsd   Float    @default(0)
  updatedAt DateTime @updatedAt

  @@unique([clientId, period])
}

enum SubStatus {
  ACTIVE
  PAUSED
  CANCELLED
}

model Subscription {
  id             String    @id @default(cuid())
  clientId       String
  client         Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  pack           Pack
  monthlyUsd     Float
  status         SubStatus @default(ACTIVE)
  mpPreapprovalId String? // Mercado Pago — F8 (diferido)
  startedAt      DateTime  @default(now())
  cancelledAt    DateTime?
}

enum InvoiceType {
  A
  B
}

model Invoice {
  id        String      @id @default(cuid())
  clientId  String
  client    Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  type      InvoiceType @default(A)
  concept   String
  amountUsd Float
  amountArs Float?
  status    String      @default("pending") // pending | paid | overdue
  dueDate   DateTime?
  paidAt    DateTime?
  createdAt DateTime    @default(now())
}

model Report {
  id        String    @id @default(cuid())
  clientId  String
  client    Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  period    String // "2026-06"
  content   Json // métricas + resumen generado
  sentAt    DateTime?
  createdAt DateTime  @default(now())

  @@unique([clientId, period])
}

// PricingConfig — singleton editable, NADA hardcodeado
model PricingConfig {
  id              String   @id @default("singleton")
  dolarArs        Float    @default(1200) // valor del dólar editable
  ivaPct          Float    @default(21)
  packs           Json // { starter:{setupUsd,monthlyUsd,fairUseMsgs}, pro:{...}, scale:{...}, custom:{...} }
  modulePricing   Json // { crm:{monthlyUsd}, turnos:{...}, catalogo:{...}, rrhh:{...}, caja:{...} }
  roadmapPriceUsd Float    @default(0) // 0 = consultoría con roadmap gratis
  roadmapCredit   Boolean  @default(true) // roadmap pago se acredita al setup
  updatedAt       DateTime @updatedAt
}

// ════════════════════════════════════════════════
// CAUCE OS — MÓDULOS (todo scopeado por clientId = tenantId)
// ════════════════════════════════════════════════

// Módulo CRM
model Contact {
  id          String   @id @default(cuid())
  clientId    String // tenant
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name        String
  phone       String?
  email       String?
  stage       String   @default("nuevo") // pipeline simple configurable
  temperatura String   @default("tibio") // caliente | tibio | frio (urgencia comercial)
  source      String? // bot | manual | web
  notes       String?
  custom      Json? // campos custom del tenant
  lastTouchAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  appointments Appointment[]
  tasks        CrmTask[]
  records      ContactRecord[]
  ordenesTrabajo OrdenTrabajo[]
  ventas       Venta[]
  presupuestosTaller PresupuestoTaller[]
  pantallaContratos PantallaContrato[]

  @@index([clientId])
  @@index([clientId, lastTouchAt])
}

model CrmTask {
  id        String    @id @default(cuid())
  clientId  String
  client    Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  contactId String?
  contact   Contact?  @relation(fields: [contactId], references: [id], onDelete: SetNull)
  title     String
  dueAt     DateTime?
  done      Boolean   @default(false)
  createdAt DateTime  @default(now())

  @@index([clientId])
}

// Módulo Turnos & Agenda
enum ApptStatus {
  PENDING
  CONFIRMED
  CANCELLED
  DONE
}

model Appointment {
  id        String     @id @default(cuid())
  clientId  String // tenant
  client    Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  contactId String?
  contact   Contact?   @relation(fields: [contactId], references: [id], onDelete: SetNull)
  employeeId String? // recurso (profe/doctor/empleado) con quien es el turno
  employee   Employee?  @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  title     String
  startsAt  DateTime
  endsAt    DateTime
  status    ApptStatus @default(PENDING)
  source    String     @default("manual") // bot | manual | web | auto-agendado
  notes     String?
  custom    Json?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([clientId, startsAt])
  @@index([employeeId])
}

model Availability {
  id          String @id @default(cuid())
  clientId    String
  client      Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  weekday     Int // 0=domingo .. 6=sábado
  startTime   String // "09:00"
  endTime     String // "18:00"
  slotMinutes Int    @default(30)

  @@index([clientId])
}

// Módulo Catálogo & Stock (F7 — modelo listo)
model Product {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name      String
  priceUsd  Float?
  priceArs  Float?
  stock     Int      @default(0)
  minStock  Int      @default(0)
  talles    Json? // stock por talle: { "S": 3, "M": 5 } — si existe, stock = suma
  photo     String?
  active    Boolean  @default(true)
  custom    Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
}

// Módulo RRHH (F7 — modelo listo)
model Employee {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name      String
  phone     String?
  role      String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  timeEntries  TimeEntry[]
  appointments Appointment[]

  @@index([clientId])
}

model TimeEntry {
  id         String    @id @default(cuid())
  clientId   String
  client     Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  employeeId String
  employee   Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  clockIn    DateTime
  clockOut   DateTime?
  source     String    @default("web") // web | whatsapp
  createdAt  DateTime  @default(now())

  @@index([clientId])
}

// Módulo Caja & Reportes (F7 — modelo listo)
model CashMovement {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  kind      String // venta | gasto | ajuste | transferencia
  concept   String
  amountArs Float
  method    String? // efectivo | mp | transferencia
  date      DateTime @default(now()) // fecha contable del movimiento
  accountId String? // cuenta afectada
  account   Account? @relation("AccountMovements", fields: [accountId], references: [id], onDelete: SetNull)
  toAccountId String? // cuenta destino (solo transferencias)
  toAccount   Account? @relation("AccountTransfersIn", fields: [toAccountId], references: [id], onDelete: SetNull)
  attachmentUrl String? // comprobante (Cloudinary)
  createdAt DateTime @default(now())

  @@index([clientId])
  @@index([clientId, date])
  @@index([accountId])
}

// Taller — órdenes de trabajo (patrón MF/VB): ingreso → diagnóstico →
// aprobado → en reparación → lista → entregada. Items de repuestos y mano
// de obra, total/pagado/saldo, y aviso automático al cliente cuando está lista.
enum OtEstado {
  INGRESADA
  EN_DIAGNOSTICO
  APROBADA
  EN_REPARACION
  LISTA
  ENTREGADA
  CANCELADA
}

model OrdenTrabajo {
  id            String   @id @default(cuid())
  clientId      String
  client        Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  numero        Int // secuencial por tenant (OT-0042)
  contactId     String?
  contact       Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  equipo        String // "Vespa Primavera 150 · AB123CD", "Bici MTB rodado 29"...
  motivoIngreso String
  diagnostico   String?
  trabajos      String? // qué se le hizo
  items         Json? // [{descripcion, cantidad, precioArs, tipo: "repuesto"|"mano_obra"}]
  totalArs      Float    @default(0)
  pagadoArs     Float    @default(0)
  estado        OtEstado @default(INGRESADA)
  entregadaAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([clientId, numero])
  @@index([clientId, estado])
}

// Propuesta comercial enviable: link público con el presupuesto armado
// y botón de aceptar. Cuando el cliente la abre queda VISTA; si acepta,
// entra como lead ganado al pipeline de Cauce.
enum PropuestaEstado {
  ENVIADA
  VISTA
  ACEPTADA
  RECHAZADA
}

model Propuesta {
  id             String          @id @default(cuid())
  token          String          @unique @default(cuid()) // /p/<token>
  negocio        String
  contactoNombre String?
  whatsapp       String?
  rubro          String?
  pack           Pack
  setupUsd       Float
  monthlyUsd     Float
  dolarArs       Float           @default(0) // cotización al momento de armarla
  conIva         Boolean         @default(false)
  ivaPct         Float           @default(21)
  modulos        String[]        @default([])
  procesoKeys    String[]        @default([])
  piezas         String[]        @default([]) // keys de src/lib/piezas.ts
  horasSemana    Float           @default(0) // horas/semana que recupera
  casoEspejo     String? // key de ESPEJOS
  nota           String?
  estado         PropuestaEstado @default(ENVIADA)
  vistaAt        DateTime?
  respondidaAt   DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([estado, createdAt])
}

// Actividad (patrón La Base): registro inmutable de acciones sensibles.
// Quién hizo qué y cuándo — caja, ventas, taller, procesos, equipo.
model Actividad {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  usuario   String?
  accion    String // "caja_abierta" | "venta_entregada" | ...
  detalle   String?
  createdAt DateTime @default(now())

  @@index([clientId, createdAt])
}

// Eventos deportivos con cronometraje (patrón Vespa Club): inscripción
// pública con número elegido, cronómetro con penalizaciones y ranking
// en vivo en la web del negocio.
model Evento {
  id                    String   @id @default(cuid())
  clientId              String
  client                Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  nombre                String // "1ª Gymkhana Oficial"
  fecha                 String // "2026-08-15"
  lugar                 String?
  categorias            String[] @default([]) // ["Clásica", "Moderna", "Libre"]
  cupo                  Int      @default(100)
  inscripcionesAbiertas Boolean  @default(true)
  activo                Boolean  @default(true) // el que se muestra en la web pública
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  competidores Competidor[]

  @@index([clientId, activo])
}

model Competidor {
  id        String   @id @default(cuid())
  eventoId  String
  evento    Evento   @relation(fields: [eventoId], references: [id], onDelete: Cascade)
  numero    Int // 1-999, elegido por el piloto
  nombre    String
  telefono  String?
  categoria String
  intentos  Json     @default("[]") // [{ms, penalSeg, dsq}]
  fuente    String   @default("admin") // admin | publica
  createdAt DateTime @default(now())

  @@unique([eventoId, numero])
  @@index([eventoId])
}

// Ventas (patrón MF): la operación grande con seña, permuta y cuotas.
// El saldo vivo = precio − seña − permuta − pagos.
enum VentaEstado {
  SENADA
  ENTREGADA
  CANCELADA
}

model Venta {
  id              String      @id @default(cuid())
  clientId        String
  client          Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  numero          Int // secuencial por tenant (V-0012)
  contactId       String?
  contact         Contact?    @relation(fields: [contactId], references: [id], onDelete: SetNull)
  descripcion     String // "Vespa Primavera 150 0km roja"
  precioArs       Float
  senaArs         Float       @default(0)
  permutaDetalle  String? // qué entregó en parte de pago
  permutaValorArs Float       @default(0)
  pagos           Json? // [{fecha: "2026-07-10", montoArs, medio}]
  cuotas          Json? // {cantidad, valorArs, diaVencimiento} — financiación propia
  estado          VentaEstado @default(SENADA)
  entregadaAt     DateTime?
  notas           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@unique([clientId, numero])
  @@index([clientId, estado])
}

// Presupuestos del taller (patrón MF): cotizar SIN ingresar el equipo.
// Si el cliente acepta, se convierte en OT con un clic (items incluidos).
enum PresupuestoEstado {
  BORRADOR
  ENVIADO
  ACEPTADO
  RECHAZADO
}

model PresupuestoTaller {
  id          String            @id @default(cuid())
  clientId    String
  client      Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  numero      Int // P-0007, secuencial por tenant
  contactId   String?
  contact     Contact?          @relation(fields: [contactId], references: [id], onDelete: SetNull)
  equipo      String
  detalle     String // qué se cotiza
  items       Json? // [{descripcion, cantidad, precioArs, tipo}]
  totalArs    Float             @default(0)
  validezDias Int               @default(15)
  estado      PresupuestoEstado @default(BORRADOR)
  otId        String? // OT generada al aceptar
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@unique([clientId, numero])
  @@index([clientId, estado])
}

// Costos fijos del negocio (patrón MF/VB): alquiler, sueldos, servicios.
// Contra el balance del mes dan el punto de equilibrio real.
model CostoFijo {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  concepto  String // "Alquiler", "Sueldos", "Luz y gas"...
  montoArs  Float
  orden     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId, orden])
}

// Lista de espera (patrón La Base): cuando un día está lleno el cliente final
// se anota; al liberarse un lugar (turno cancelado) se genera el aviso con
// WhatsApp listo para el primero de la fila.
enum EsperaEstado {
  ESPERANDO
  AVISADO
  BAJA
}

model ListaEspera {
  id        String       @id @default(cuid())
  clientId  String
  client    Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  fecha     String // "2026-07-15" — el día que buscaba
  nombre    String
  telefono  String
  estado    EsperaEstado @default(ESPERANDO)
  createdAt DateTime     @default(now())

  @@index([clientId, fecha, estado])
}

// Outreach (patrón Motos Fernández): tareas de contacto generadas por los
// procesos (cron diario) con el mensaje de WhatsApp pre-armado. El dueño
// las despacha a 1 clic y quedan marcadas.
enum OutreachEstado {
  PROGRAMADA
  ENVIADA
  DESCARTADA
}

model OutreachTarea {
  id              String         @id @default(cuid())
  clientId        String
  client          Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tipo            String // "recordatorio-turno" | "seguimiento-consulta" | ...
  contactId       String?
  appointmentId   String?
  nombre          String // a quién
  telefono        String?
  mensaje         String // texto exacto listo para mandar
  fechaProgramada String // "2026-07-10" (día argentino)
  estado          OutreachEstado @default(PROGRAMADA)
  enviadaAt       DateTime?
  createdAt       DateTime       @default(now())

  @@index([clientId, estado, fechaProgramada])
  @@index([clientId, tipo, fechaProgramada])
}

// Arqueo de caja diario (patrón La Base): abrís con saldo inicial por moneda,
// el día suma el efectivo que entra/sale, cerrás contando lo real y queda la
// diferencia registrada. Un arqueo por día por cliente.
model CajaDia {
  id        String    @id @default(cuid())
  clientId  String
  client    Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  fecha     String // "2026-07-08" (día argentino)
  abiertaEl DateTime  @default(now())
  cerradaEl DateTime?
  usuario   String? // quién abrió/cerró

  saldos CajaSaldo[]

  @@unique([clientId, fecha])
  @@index([clientId, fecha])
}

model CajaSaldo {
  id           String  @id @default(cuid())
  cajaDiaId    String
  cajaDia      CajaDia @relation(fields: [cajaDiaId], references: [id], onDelete: Cascade)
  moneda       String // ARS | USD
  saldoInicial Float   @default(0)
  ingresos     Float   @default(0) // efectivo entrado (foto al cierre)
  egresos      Float   @default(0) // efectivo salido (foto al cierre)
  contado      Float? // lo contado real al cerrar
  diferencia   Float? // contado − esperado

  @@unique([cajaDiaId, moneda])
}

// Módulo Finanzas — cuentas/billeteras del negocio con saldo propio
model Account {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name      String // "Efectivo", "Banco Galicia", "Mercado Pago", "Dólares"...
  kind      String   @default("efectivo") // efectivo | banco | mp | dolares | cheques | otro
  currency  String   @default("ARS") // ARS | USD
  balance   Float    @default(0) // saldo actual
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  movements    CashMovement[] @relation("AccountMovements")
  transfersIn  CashMovement[] @relation("AccountTransfersIn")

  @@index([clientId])
}

// Ficha/historial del contacto: cada consulta, servicio o reparación suma una entrada
model ContactRecord {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  contactId String
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  type      String   @default("nota") // consulta | servicio | reparacion | visita | nota
  date      DateTime @default(now())
  title     String?
  summary   String?
  fields    Json? // campos del rubro (diagnóstico/tratamiento, trabajo/repuestos, etc.)
  authorId  String? // empleado/profesional que la cargó
  createdAt DateTime @default(now())

  attachments Attachment[]

  @@index([clientId])
  @@index([contactId])
}

// Adjuntos (fotos, PDFs, documentos) guardados en Cloudinary, scopeados por tenant
model Attachment {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  recordId  String?
  record    ContactRecord? @relation(fields: [recordId], references: [id], onDelete: Cascade)
  // Adjunto genérico: cuelga de cualquier entidad del OS por referencia.
  refType   String? // "ot" | "venta" | "contact" | ...
  refId     String?
  url       String
  publicId  String? // id en Cloudinary (para borrar)
  name      String
  mime      String?
  bytes     Int?
  createdAt DateTime @default(now())

  @@index([clientId])
  @@index([recordId])
  @@index([clientId, refType, refId])
}

// Propiedades de la inmobiliaria (catálogo público). Reutilizable como listing genérico.
model Listing {
  id           String   @id @default(cuid())
  clientId     String
  client       Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  slug         String // para la URL pública /sitio/<tenant>/<slug>
  title        String
  operation    String   @default("venta") // venta | alquiler | alquiler_temporal
  propertyType String   @default("departamento") // casa | departamento | ph | local | terreno | oficina | galpon
  status       String   @default("disponible") // disponible | reservada | vendida | alquilada
  priceUsd     Float?
  priceArs     Float?
  expensesArs  Float? // expensas mensuales
  address      String?
  neighborhood String?
  city         String?
  bedrooms     Int? // ambientes/dormitorios
  bathrooms    Int?
  areaM2       Float?
  coveredM2    Float?
  description  String?
  amenities    String[] @default([]) // [cochera, pileta, parrilla, balcón...]
  photos       String[] @default([]) // URLs Cloudinary
  featured     Boolean  @default(false) // destacada en la home del sitio
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([clientId])
  @@index([clientId, status])
}

// Proyectos de la agencia (gestión de principio a fin)
model Proyecto {
  id          String   @id @default(cuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name        String
  clienteName String? // el cliente de la agencia para quien es el proyecto
  status      String   @default("propuesta") // propuesta | en_curso | revision | entregado | pausado
  area        String? // branding | ads | redes | web | contenido | SEO
  budgetUsd   Float?
  startDate   DateTime?
  dueDate     DateTime?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tareas      ProyectoTarea[]

  @@index([clientId])
}

model ProyectoTarea {
  id         String   @id @default(cuid())
  clientId   String
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  proyectoId String
  proyecto   Proyecto @relation(fields: [proyectoId], references: [id], onDelete: Cascade)
  title      String
  status     String   @default("pendiente") // pendiente | haciendo | revision | hecho
  assigneeId String? // Employee del tenant
  dueAt      DateTime?
  hours      Float? // horas estimadas/cargadas
  orderIdx   Int      @default(0)
  createdAt  DateTime @default(now())

  @@index([clientId])
  @@index([proyectoId])
}

// ── Marketing de Cauce: publicaciones IG/FB + Meta Ads del propio negocio ──

/// Conexión con Meta (fila única id="default"). Tokens cifrados con crypto.ts.
model MktConfig {
  id               String    @id @default("default")
  userId           String?
  userName         String?
  pageId           String?
  pageName         String?
  pageAccessToken  String?   @db.Text // cifrado AES-256-GCM
  igUserId         String?
  igUsername       String?
  expiresAt        DateTime?
  scope            String?
  apiVersion       String    @default("v25.0")
  lastTokenCheckAt DateTime?
  adAccountId      String? // "act_XXXX"
  businessId       String?
  pixelId          String?
  adsTokenScopes   Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

/// Publicación propia (feed/reel) — borrador, programada o publicada.
model MktPost {
  id            String    @id @default(cuid())
  titulo        String // nombre interno para la lista
  caption       String    @db.Text
  idea          String?   @db.Text // brief visual para diseñar la pieza (Claude design)
  mediaType     String    @default("PHOTO") // PHOTO | PHOTO_CAROUSEL | VIDEO | REEL
  imageUrls     String[]  @default([])
  videoUrls     String[]  @default([])
  platforms     String[]  @default(["IG"]) // IG | FB
  scheduledAt   DateTime? // null = borrador sin fecha
  status        String    @default("DRAFT") // DRAFT|PENDING|PROCESSING|PUBLISHED|PARTIAL|FAILED|CANCELLED
  publishedAt   DateTime?
  publishedRefs Json? // { ig: {postId, permalink}, fb: {...} }
  errorMessage  String?   @db.Text
  retryCount    Int       @default(0)
  lockedAt      DateTime?
  lockedBy      String?
  origen        String    @default("manual") // manual | ia
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status, scheduledAt])
}

/// Campaña de Meta Ads (1 campaña = 1 adset + 1 ad, como la v1 de MF).
model MktCampaign {
  id                   String    @id @default(cuid())
  name                 String
  objective            String // OUTCOME_TRAFFIC|OUTCOME_ENGAGEMENT|OUTCOME_LEADS|OUTCOME_AWARENESS
  metaCampaignId       String?   @unique
  metaAdSetId          String?   @unique
  metaAdId             String?   @unique
  metaCreativeId       String?
  dailyBudgetCents     Int // centavos ARS
  startDate            DateTime
  endDate              DateTime
  status               String    @default("DRAFT") // DRAFT|IN_META_PAUSED|ACTIVE|PAUSED_BY_USER|COMPLETED|FAILED|DELETED
  audienceConfig       Json // { ageMin, ageMax, genders, countries, cities, interests }
  creativeMediaType    String    @default("PHOTO") // PHOTO|PHOTO_CAROUSEL|VIDEO|REEL
  creativeImageUrls    String[]  @default([])
  creativeVideoUrl     String?   @db.Text
  creativeCaption      String    @db.Text
  creativeCallToAction String    @default("LEARN_MORE")
  destinationUrl       String?   @db.Text
  insightsCache        Json? // { reach, impressions, clicks, ctr, cpm, cpc, spend, syncedAt }
  lastSyncedAt         DateTime?
  errorMessage         String?   @db.Text
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([status, endDate])
}

// ── Pantallas LED (rubro DOOH — Ave Fénix) ──────────────────────────────

/// Una pantalla física del circuito: ubicación, medidas y capacidad de spots.
model Pantalla {
  id         String  @id @default(cuid())
  clientId   String
  client     Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  nombre     String // "Zelarrayán e Yrigoyen"
  zona       String? // "Microcentro", "Monte Hermoso"…
  medidas    String? // "6x3 m"
  resolucion String? // "800x480 px"
  fotoUrl    String?
  slotsTotal Int     @default(30) // spots de 15s que entran en la rotación
  activa     Boolean @default(true)
  orden      Int     @default(0)

  contratos PantallaContrato[]

  @@index([clientId])
}

/// Contrato de un anunciante en una pantalla: N spots por un monto mensual.
model PantallaContrato {
  id           String    @id @default(cuid())
  clientId     String
  client       Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  pantallaId   String
  pantalla     Pantalla  @relation(fields: [pantallaId], references: [id], onDelete: Cascade)
  contactId    String?
  contact      Contact?  @relation(fields: [contactId], references: [id], onDelete: SetNull)
  slots        Int       @default(1)
  montoMensual Float     @default(0) // ARS por mes
  estado       String    @default("activo") // activo | pausado | baja
  inicio       DateTime?
  fin          DateTime?
  notas        String?
  createdAt    DateTime  @default(now())

  @@index([clientId])
  @@index([pantallaId])
  @@index([contactId])
}
